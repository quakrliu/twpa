---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION_EN, SITE_TITLE_EN } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const posts = (await getCollection('blog'))
	.filter((p) => p.data.lang === 'en')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE_EN} description={SITE_DESCRIPTION_EN} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img src="/images/banner.png" alt="True Wisdom Practitioners Association" class="hero-banner" />
				<h1>True Wisdom Practitioners Association</h1>
				<p class="hero-desc">
					A welcoming space for all who are drawn to the timeless wisdom of the East.
					Together, we explore the depths of Buddhist and Chan teachings — cultivating
					mindful living, plant-based wellness, and a gentle, grounded approach to emotional well-being.
				</p>
			</section>

			<div class="content-layout">
				<section class="latest-posts">
					<h2>Latest Articles</h2>
					<ul>
						{
							posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<h4 class="post-title">{post.data.title}</h4>
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										{post.data.description && (
											<p class="post-desc">{post.data.description}</p>
										)}
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<aside class="sidebar">
					<div class="sidebar-section">
						<h3>Explore Topics</h3>
						<div class="category-list">
							<a href="/en/category/mindful-living" class="cat-card">Mindful Living</a>
							<a href="/en/category/plant-based-wellness" class="cat-card">Plant-Based Wellness</a>
							<a href="/en/category/emotional-wellbeing" class="cat-card">Emotional Well-Being</a>
							<a href="/en/category/chan-meditation" class="cat-card">Chan & Meditation</a>
							<a href="/en/category/community-events" class="cat-card">Community Events</a>
						</div>
					</div>

					<div class="sidebar-section newsletter-form">
						<h3>Stay Connected</h3>
						<p>Receive our latest articles on mindful living, Buddhist wisdom, and upcoming events.</p>
						<form
							action="https://subscribe-forms.beehiiv.com/TWPA_PUBLICATION_ID"
							method="POST"
							target="_blank"
						>
							<input type="email" name="email" placeholder="Your email address" required />
							<button type="submit">Subscribe</button>
						</form>
						<p class="form-note">No spam. Unsubscribe anytime.</p>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		margin-bottom: 3em;
	}
	.hero-banner {
		width: 100%;
		max-width: 480px;
		margin: 0 auto 1.5em;
		border-radius: 8px;
	}
	.hero h1 {
		font-size: 2.2em;
		color: var(--accent-dark);
		margin-bottom: 0.5em;
	}
	.hero-desc {
		font-size: 1.1em;
		color: rgb(var(--gray));
		max-width: 55ch;
		margin: 0 auto;
		line-height: 1.7;
	}
	.content-layout {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 3em;
		margin: 3em 0;
	}
	.latest-posts h2 {
		font-size: 1.6em;
		border-bottom: 2px solid var(--gold);
		padding-bottom: 0.3em;
		margin-bottom: 1em;
	}
	.latest-posts ul {
		list-style: none;
		padding: 0;
	}
	.latest-posts li {
		margin-bottom: 1.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.latest-posts li:last-child {
		border-bottom: none;
	}
	.latest-posts a {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	.latest-posts a:hover .post-title {
		color: var(--accent);
	}
	.post-title {
		margin: 0 0 0.2em;
		font-size: 1.2em;
		transition: color 0.2s ease;
	}
	.post-date {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0 0 0.4em;
	}
	.post-desc {
		font-size: 0.95em;
		color: rgb(var(--gray));
		margin: 0;
	}
	.sidebar {
		position: sticky;
		top: 2em;
		align-self: start;
	}
	.sidebar-section {
		margin-bottom: 2em;
		padding: 1.2em;
		background: var(--warm-white, #FEFCF8);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
	}
	.sidebar-section h3 {
		font-size: 1.1em;
		color: var(--accent-dark);
		margin-bottom: 0.8em;
		padding-bottom: 0.4em;
		border-bottom: 2px solid var(--gold);
	}
	.category-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.cat-card {
		display: block;
		padding: 0.6em 0.8em;
		background: var(--cream);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 0.85em;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.cat-card:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.sidebar .newsletter-form {
		text-align: left;
		background: var(--warm-white, #FEFCF8);
	}
	.sidebar .newsletter-form p {
		font-size: 0.85em;
		max-width: none;
	}
	.sidebar .newsletter-form input[type="email"] {
		width: 100%;
		margin: 0 0 0.5em;
		box-sizing: border-box;
	}
	.sidebar .newsletter-form button {
		width: 100%;
	}
	.form-note {
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin-top: 0.5em;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.8em;
		}
		.content-layout {
			grid-template-columns: 1fr;
			gap: 2em;
		}
		.sidebar {
			position: static;
		}
	}
</style>
