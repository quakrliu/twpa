---
import BaseHead from '../../../components/BaseHead.astro';
import Footer from '../../../components/Footer.astro';
import Header from '../../../components/Header.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import { SITE_TITLE_EN } from '../../../consts';
import { getCollection } from 'astro:content';

const categoryLabels: Record<string, string> = {
	'mindful-living': 'Mindful Living',
	'plant-based-wellness': 'Plant-Based Wellness',
	'emotional-wellbeing': 'Emotional Well-Being',
	'chan-meditation': 'Chan & Meditation',
	'community-events': 'Community Events',
};

export async function getStaticPaths() {
	return Object.keys({
		'mindful-living': true,
		'plant-based-wellness': true,
		'emotional-wellbeing': true,
		'chan-meditation': true,
		'community-events': true,
	}).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const label = categoryLabels[category!] || category;
const posts = (await getCollection('blog'))
	.filter((p) => p.data.category === category && p.data.lang === 'en')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`${label} — ${SITE_TITLE_EN}`} description={`Articles about ${label}`} />
	</head>
	<body>
		<Header />
		<main>
			<h1>{label}</h1>
			{posts.length === 0 && <p>No articles in this category yet. Check back soon.</p>}
			<ul class="post-list">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`}>
							<h4>{post.data.title}</h4>
							<p class="meta"><FormattedDate date={post.data.pubDate} /></p>
							{post.data.description && <p class="desc">{post.data.description}</p>}
						</a>
					</li>
				))}
			</ul>
		</main>
		<Footer />
	</body>
</html>

<style>
	h1 {
		font-size: 2em;
		border-bottom: 2px solid var(--gold);
		padding-bottom: 0.3em;
		margin-bottom: 1em;
	}
	.post-list {
		list-style: none;
		padding: 0;
	}
	.post-list li {
		margin-bottom: 1.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.post-list a {
		text-decoration: none;
		color: inherit;
	}
	.post-list a:hover h4 {
		color: var(--accent);
	}
	.meta {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0.2em 0 0.4em;
	}
	.desc {
		font-size: 0.95em;
		color: rgb(var(--gray));
		margin: 0;
	}
</style>
