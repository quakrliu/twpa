---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<img src="/images/banner.png" alt="智慧修行協會" class="hero-banner" />
				<h1>智慧修行協會</h1>
				<p class="hero-sub">True Wisdom Practitioners Association</p>
				<p class="hero-desc">
					歡迎所有嚮往東方智慧的朋友。我們一起探索佛法與禪宗的深邃教義——在日常中培養正念生活、健康飲食與平靜的身心。
				</p>
			</section>

			<div class="content-layout">
				<section class="latest-posts">
					<h2>最新文章</h2>
					<ul>
						{
							posts.map((post) => (
								<li>
									<a href={`/blog/${post.id}/`}>
										<h4 class="post-title">{post.data.title}</h4>
										<p class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</p>
										{post.data.description && (
											<p class="post-desc">{post.data.description}</p>
										)}
									</a>
								</li>
							))
						}
					</ul>
				</section>

				<aside class="sidebar">
					<div class="sidebar-section">
						<h3>探索主題</h3>
						<div class="category-list">
							<a href="/category/mindful-living" class="cat-card">正念生活</a>
							<a href="/category/plant-based-wellness" class="cat-card">蔬食與健康</a>
							<a href="/category/emotional-wellbeing" class="cat-card">情緒管理</a>
							<a href="/category/chan-meditation" class="cat-card">禪修與冥想</a>
							<a href="/category/community-events" class="cat-card">活動與講座</a>
						</div>
					</div>

					<div class="sidebar-section newsletter-form">
						<h3>訂閱電子報</h3>
						<p>接收最新的正念生活、佛法智慧與大洋洲活動資訊。</p>
						<form
							action="https://subscribe-forms.beehiiv.com/TWPA_PUBLICATION_ID"
							method="POST"
							target="_blank"
						>
							<input type="email" name="email" placeholder="請輸入您的 Email" required />
							<button type="submit">訂閱</button>
						</form>
						<p class="form-note">不會寄送垃圾郵件，隨時可以退訂。</p>
					</div>
				</aside>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		text-align: center;
		margin-bottom: 3em;
	}
	.hero-banner {
		width: 100%;
		max-width: 480px;
		margin: 0 auto 1.5em;
		border-radius: 8px;
	}
	.hero h1 {
		font-size: 2.2em;
		color: var(--accent-dark);
		margin-bottom: 0.2em;
	}
	.hero-sub {
		font-size: 1em;
		color: rgb(var(--gray));
		margin: 0 auto 1em;
		letter-spacing: 0.05em;
	}
	.hero-desc {
		font-size: 1.1em;
		color: rgb(var(--gray));
		max-width: 55ch;
		margin: 0 auto;
		line-height: 1.7;
	}
	.content-layout {
		display: grid;
		grid-template-columns: 1fr 280px;
		gap: 3em;
		margin: 3em 0;
	}
	.latest-posts h2 {
		font-size: 1.6em;
		border-bottom: 2px solid var(--gold);
		padding-bottom: 0.3em;
		margin-bottom: 1em;
	}
	.latest-posts ul {
		list-style: none;
		padding: 0;
	}
	.latest-posts li {
		margin-bottom: 1.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	.latest-posts li:last-child {
		border-bottom: none;
	}
	.latest-posts a {
		text-decoration: none;
		color: inherit;
		display: block;
	}
	.latest-posts a:hover .post-title {
		color: var(--accent);
	}
	.post-title {
		margin: 0 0 0.2em;
		font-size: 1.2em;
		transition: color 0.2s ease;
	}
	.post-date {
		font-size: 0.85em;
		color: rgb(var(--gray));
		margin: 0 0 0.4em;
	}
	.post-desc {
		font-size: 0.95em;
		color: rgb(var(--gray));
		margin: 0;
	}
	.sidebar {
		position: sticky;
		top: 2em;
		align-self: start;
	}
	.sidebar-section {
		margin-bottom: 2em;
		padding: 1.2em;
		background: var(--warm-white, #FEFCF8);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 8px;
	}
	.sidebar-section h3 {
		font-size: 1.1em;
		color: var(--accent-dark);
		margin-bottom: 0.8em;
		padding-bottom: 0.4em;
		border-bottom: 2px solid var(--gold);
	}
	.category-list {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
	}
	.cat-card {
		display: block;
		padding: 0.6em 0.8em;
		background: var(--cream);
		border: 1px solid rgb(var(--gray-light));
		border-radius: 6px;
		text-decoration: none;
		color: rgb(var(--gray-dark));
		font-weight: 600;
		font-size: 0.85em;
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.cat-card:hover {
		border-color: var(--accent);
		color: var(--accent);
	}
	.sidebar .newsletter-form {
		text-align: left;
		background: var(--warm-white, #FEFCF8);
	}
	.sidebar .newsletter-form p {
		font-size: 0.85em;
		max-width: none;
	}
	.sidebar .newsletter-form input[type="email"] {
		width: 100%;
		margin: 0 0 0.5em;
		box-sizing: border-box;
	}
	.sidebar .newsletter-form button {
		width: 100%;
	}
	.form-note {
		font-size: 0.75em;
		color: rgb(var(--gray));
		margin-top: 0.5em;
	}
	@media (max-width: 720px) {
		.hero h1 {
			font-size: 1.8em;
		}
		.content-layout {
			grid-template-columns: 1fr;
			gap: 2em;
		}
		.sidebar {
			position: static;
		}
	}
</style>
