---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="logo-link">
			<img src="/images/logo.jpg" alt="TWPA Logo" class="logo" />
			<span class="site-name">TWPA</span>
		</a>
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/category/mindful-living">Mindful Living</HeaderLink>
			<HeaderLink href="/category/chan-meditation">Chan</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--warm-white, #FEFCF8);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 760px;
		margin: 0 auto;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.6em;
		text-decoration: none;
		padding: 0.75em 0;
	}
	.logo {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
	}
	.site-name {
		font-weight: 700;
		font-size: 1.1em;
		color: rgb(var(--black));
		letter-spacing: 0.05em;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--gray-dark));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
		transition: border-color 0.2s ease;
	}
	nav a:hover,
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		color: var(--accent-dark);
	}
	@media (max-width: 720px) {
		.site-name {
			display: none;
		}
	}
</style>
