---
import HeaderLink from './HeaderLink.astro';

const { lang = 'zh' } = Astro.props;
const isEn = lang === 'en';
---

<header>
	<nav>
		<a href={isEn ? '/en' : '/'} class="logo-link">
			<img src="/images/logo.jpg" alt="TWPA Logo" class="logo" />
			<span class="site-name">TWPA</span>
		</a>
		<div class="nav-right">
			<div class="internal-links">
				{isEn ? (
					<HeaderLink href="/en">Home</HeaderLink>
					<HeaderLink href="/en/blog">Blog</HeaderLink>
					<HeaderLink href="/en/about">About</HeaderLink>
				) : (
					<HeaderLink href="/">首頁</HeaderLink>
					<HeaderLink href="/blog">文章</HeaderLink>
					<HeaderLink href="/about">關於我們</HeaderLink>
				)}
			</div>
			<div class="lang-toggle">
				<a href="/" class={`lang-btn ${!isEn ? 'active' : ''}`}>中文</a>
				<span class="lang-sep">|</span>
				<a href="/en" class={`lang-btn ${isEn ? 'active' : ''}`}>EN</a>
			</div>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: var(--warm-white, #FEFCF8);
		border-bottom: 1px solid rgb(var(--gray-light));
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: 1080px;
		margin: 0 auto;
	}
	.logo-link {
		display: flex;
		align-items: center;
		gap: 0.6em;
		text-decoration: none;
		padding: 0.75em 0;
	}
	.logo {
		width: 40px;
		height: 40px;
		border-radius: 50%;
		object-fit: cover;
	}
	.site-name {
		font-weight: 700;
		font-size: 1.1em;
		color: rgb(var(--black));
		letter-spacing: 0.05em;
	}
	.nav-right {
		display: flex;
		align-items: center;
		gap: 1.5em;
	}
	.internal-links {
		display: flex;
	}
	nav a {
		padding: 1em 0.5em;
		color: rgb(var(--gray-dark));
		border-bottom: 3px solid transparent;
		text-decoration: none;
		font-size: 0.95em;
		transition: border-color 0.2s ease;
	}
	nav a:hover,
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
		color: var(--accent-dark);
	}
	.lang-toggle {
		display: flex;
		align-items: center;
		gap: 0.3em;
		font-size: 0.85em;
	}
	.lang-btn {
		padding: 0.3em 0.5em !important;
		border-bottom: none !important;
		color: rgb(var(--gray)) !important;
		font-weight: 400;
	}
	.lang-btn.active {
		color: var(--accent-dark) !important;
		font-weight: 700;
	}
	.lang-sep {
		color: rgb(var(--gray-light));
	}
	@media (max-width: 720px) {
		.site-name {
			display: none;
		}
		.internal-links {
			gap: 0;
		}
		nav a {
			padding: 1em 0.3em;
			font-size: 0.85em;
		}
	}
</style>
